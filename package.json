{
	"name": "placemento",
	"version": "1.0.0",
	"description": "MCA Placement Portal",
	"scripts": {
		"dev": "concurrently \"pnpm run server\" \"pnpm run client\"",
		"server": "pnpm --filter server dev",
		"client": "pnpm --filter client dev",
		"build": "pnpm --filter client build",
		"start": "concurrently \"pnpm run backend-start\" \"pnpm run frontend-start\"",
		"backend-start": "pnpm --filter server start",
		"frontend-start": "pnpm --filter client dev",
		"test": "pnpm run test:server && pnpm run test:client",
		"test:server": "pnpm --filter server test",
		"test:client": "pnpm --filter client test",
		"format": "prettier --write ."
	},
	"author": "Sagar Gupta",
	"license": "GPL-3.0",
	"packageManager": "pnpm@10.34.1",
	"pnpm": {
		"overrides": {
			"rollup@>=4.0.0 <4.59.0": ">=4.59.0",
			"picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
			"path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
			"undici@>=7.0.0 <7.24.0": ">=7.24.0",
			"lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
			"shell-quote@<=1.8.3": ">=1.8.4",
			"react-router@<7.15.0": ">=7.15.0",
			"qs@>=6.11.1 <=6.15.1": ">=6.15.2",
			"postcss@<8.5.10": ">=8.5.10",
			"esbuild": ">=0.28.1",
			"ip-address@<=10.1.0": ">=10.1.1"
		},
		"ignoredOptionalDependencies": [
			"lightningcss"
		]
	},
	"devDependencies": {
		"concurrently": "^9.2.0",
		"prettier": "^3.1.1",
		"prettier-plugin-organize-imports": "^4.0.0"
	}
}
